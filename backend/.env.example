# ─────────────────────────────────────────────────────────────
#  Environment Configuration — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/naga_ai

# JWT secret (generate a long random string for production)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenAI API key (used for AI responses)
OPENAI_API_KEY=your-openai-api-key-here

# Twilio credentials (optional — for SMS emergency alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
EMERGENCY_CONTACT_NUMBER=+0987654321

# CORS — frontend origin
FRONTEND_URL=http://localhost:5173
